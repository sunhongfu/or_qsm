{
	"name": "python-ismrmrd-server-devcon",

	"build": {
		"dockerfile": "../docker/Dockerfile",
		"target":     "python-mrd-devcontainer",
		"context":    "../",
		"cacheFrom":  [
			"docker.io/kspacekelvin/fire-python-devcon",
			"docker.io/kspacekelvin/fire-python:buildcache"]
	},

	// Use to enable local GPUs in container if available
	// "runArgs": [ "--gpus=all" ],

	// Use appPort to "publish" a port to the host machine. Compared to forwardPorts,
	// appPort allows connections from non-localhost
	"appPort": ["9020:9020"],

	// Bind-mount the example DICOM test dataset (kept out of the repo/workspace to avoid
	// bloating it -- you'll need your own test DICOMs at this host path, or edit it).
	// iQSM_Plus itself is NOT bind-mounted -- postCreate.sh clones it directly into the
	// container instead, so this devcontainer works out of the box for anyone, not just
	// on the original author's machine.
	"mounts": [
		"source=/Users/uqhsun8/Downloads/DICOMs_openrecon,target=/opt/data/DICOMs_openrecon,type=bind,consistency=cached"
	],

	// Tell qsm.py where postCreate.sh clones iQSM_Plus to
	"containerEnv": {
		"IQSM_PLUS_DIR": "/opt/iQSM_Plus"
	},

	// Sets core.autocrlf, installs torch/nibabel/scipy for the iQSM+ QSM module
	// (qsm.py), and clones iQSM_Plus + downloads its checkpoints -- see postCreate.sh.
	"postCreateCommand": "bash .devcontainer/postCreate.sh",

	"customizations": {
		"vscode": {
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": [
				"ms-python.debugpy",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter"
			],

			"settings": { 
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}