{
	"name": "or-qsm-devcontainer",

	// Builds from docker/qsm.dockerfile's own devcontainer-equivalent stage (not the
	// generic docker/Dockerfile) -- this host is a native linux/amd64 machine, so there's
	// no QEMU/Rosetta emulation cost and no ARM/CUDA mismatch: the CUDA torch stack builds
	// and runs natively (GPU used if present -- see "hostRequirements" below, gracefully
	// CPU-only otherwise), and vendor/bet2's amd64 binary executes directly too (it doesn't
	// need a COPY into this stage -- it arrives via the workspace bind-mount below, same
	// fallback path qsm.py already uses for local/notebook testing). This gives full
	// production fidelity *inside* the devcontainer itself, unlike on an Apple Silicon Mac
	// (see git history) where this stage would require forcing --platform linux/amd64 and
	// pay for emulation regardless of GPU availability. If you reopen this repo's
	// devcontainer on a Mac, swap "target" back to docker/Dockerfile's
	// "python-mrd-devcontainer" or it'll try to build this CUDA stage there and be
	// extremely slow.
	"build": {
		"dockerfile": "../docker/qsm.dockerfile",
		"target":     "python-mrd-cuda-devcontainer",
		"context":    "../"
	},

	// "optional" (not runArgs: ["--gpus=all"]) -- lets the devcontainers CLI's own GPU
	// detection (--gpu-availability detect, its default) enable GPU access when present
	// and silently skip it otherwise, instead of a hard Docker CLI failure on any machine
	// where the NVIDIA Container Toolkit/CDI isn't set up (or has no GPU at all, e.g. a
	// CPU-only Linux box). qsm.py/inference.py already fall back to CPU inference cleanly
	// when torch.cuda.is_available() is False, so this is a safe default everywhere.
	"hostRequirements": {
		"gpu": "optional"
	},

	// Use appPort to "publish" a port to the host machine. Compared to forwardPorts,
	// appPort allows connections from non-localhost
	"appPort": ["9020:9020"],

	// No separate DICOM test-data mount, and no bind-mount for iQSM_Plus either -- both are
	// expected to already exist as subfolders of this repo before you open the devcontainer
	// (see readme.md's "Building the Docker image" and "Local testing" sections), so VS
	// Code's default workspace bind-mount covers them automatically, live-editable, with no
	// extra mounts or postCreateCommand cloning/downloading needed. qsm.py finds iQSM_Plus
	// via a path relative to its own location (see IQSM_PLUS_DIR in qsm.py), so no
	// containerEnv override is needed either.

	// core.autocrlf: harmless/no-op on Linux, kept for parity if this devcontainer is ever
	// used cross-platform again. ipykernel: the one Python dep docker/qsm.dockerfile's
	// devcontainer stage lacks (it's dev/notebook-only, not a runtime dependency).
	"postCreateCommand": "git config --global core.autocrlf true && pip install ipykernel",

	"customizations": {
		"vscode": {
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": [
				"ms-python.debugpy",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter"
			],

			"settings": { 
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}