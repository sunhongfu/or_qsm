{
	"name": "python-ismrmrd-server-devcon",

	"build": {
		"dockerfile": "../docker/Dockerfile",
		"target":     "python-mrd-devcontainer",
		"context":    "../",
		"cacheFrom":  [
			"docker.io/kspacekelvin/fire-python-devcon",
			"docker.io/kspacekelvin/fire-python:buildcache"]
	},

	// Use to enable local GPUs in container if available
	// "runArgs": [ "--gpus=all" ],

	// Use appPort to "publish" a port to the host machine. Compared to forwardPorts,
	// appPort allows connections from non-localhost
	"appPort": ["9020:9020"],

	// Bind-mount the iQSM_Plus repo (kept as a separate checkout, not part of this
	// repo) so qsm.py can import it from inside the devcontainer, and the example
	// DICOM test dataset (kept out of the repo/workspace to avoid bloating it)
	"mounts": [
		"source=/Users/uqhsun8/Documents/repos/iQSM_Plus,target=/opt/iQSM_Plus,type=bind,consistency=cached",
		"source=/Users/uqhsun8/Downloads/DICOMs_openrecon,target=/opt/data/DICOMs_openrecon,type=bind,consistency=cached"
	],

	// Tell qsm.py where to find the mounted iQSM_Plus checkout above
	"containerEnv": {
		"IQSM_PLUS_DIR": "/opt/iQSM_Plus"
	},

	// Default setting for Windows changes files to CRLF, so match this to avoid all files
	// being marked as changed.  Could be disabled for non-Windows hosts
	// torch/nibabel/scipy are added here for the iQSM+ QSM module (qsm.py)
	"postCreateCommand": "git config --global core.autocrlf true && pip install ipykernel torch nibabel scipy",

	"customizations": {
		"vscode": {
			// Add the IDs of extensions you want installed when the container is created.
			"extensions": [
				"ms-python.debugpy",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter"
			],

			"settings": { 
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}