{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        // Alternative to the "Start QSM server" launch config, for when you'd rather not
        // open this repo in the devcontainer at all -- run this from a plain VS Code window
        // on the host (Docker isn't available *inside* the devcontainer itself, so this
        // task won't work from a terminal already connected to it). The devcontainer's own
        // "Start QSM server" launch config now runs bet2 fine directly (it forces
        // --platform linux/amd64, see .devcontainer/devcontainer.json's comments) -- this
        // task's remaining purpose is testing the already-built, tagged openrecon-qsm:prod
        // image specifically (e.g. right before packaging), or a quick server without
        // switching environments. Only the *native*, no-container "Start QSM server" launch
        // config (i.e. run outside the devcontainer too) still can't run bet2 on a
        // non-linux/amd64 host -- it always falls back to unmasked reconstruction, silently
        // (see qsm.py's _run_bet2, which catches the resulting "Exec format error").
        //
        // Maps host port 9020 -> container port 9002, so RunQSMRecon.ipynb's existing
        // `args.port = 9020` works unchanged regardless of which server variant is
        // running -- just start this task instead. Requires openrecon-qsm:prod to already
        // be built (see docker/qsm.dockerfile).
        //
        // Bind-mounts the repo over /opt/code/python-ismrmrd-server (where the image's own
        // COPY . baked the code in at build time) for live editing -- edit qsm.py, restart
        // this task, no rebuild needed. iQSM_Plus is nested inside this same repo folder
        // (see docker/qsm.dockerfile's header comment), so this one mount covers it too --
        // edit its code the same way, no second mount needed. bet2 lives at a separate path
        // (/opt/bet2), untouched by this mount, so it stays exactly as built into the image.
        {
            "label": "Start QSM server (Docker)",
            "type": "shell",
            "command": "docker",
            "args": [
                "run", "--rm", "--platform", "linux/amd64",
                "-p", "9020:9002",
                "--name", "qsm-docker-server",
                "-v", "${workspaceFolder}:/opt/code/python-ismrmrd-server",
                "openrecon-qsm:prod"
            ],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "showReuseMessage": false,
                "focus": false,
                "group": "server",
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^never matches$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Starting server.*$",
                    "endsPattern": "^.*Serving\\.\\.\\.$"
                }
            }
        },

        // Generate raw data using generate_cartesian_shepp_logan_dataset.py
        {
            "label": "Generate raw data",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceRoot}/generate_cartesian_shepp_logan_dataset.py",
                "-o", "${workspaceRoot}/data/shepplogan_raw.mrd",
            ],
            "presentation": {
                "showReuseMessage": false,
                "focus": false,
                "group": "client",
            },
            "problemMatcher": []
        },
    ]
}